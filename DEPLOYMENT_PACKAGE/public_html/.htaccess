# RRGF Website - Apache .htaccess Configuration
# For Hostinger Shared Hosting

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # API → pass original path as query param (LiteSpeed-safe; $_SERVER E= vars are unreliable)
  RewriteCond %{REQUEST_URI} ^/?api(/|$) [NC]
  RewriteRule ^api/(.*)$ api/index.php?_rrgf_path=/api/$1 [L,QSA]

  # php-backend PHP scripts must not be routed to the React SPA
  RewriteRule ^php-backend/ - [L]
  
  # Serve static files directly (don't route to index.html)
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule . - [L]
  
  # Handle React Router - serve index.php (PHP bypasses LiteSpeed static cache)
  # Exclude API, assets, and all file extensions (some hosts omit leading slash in REQUEST_URI)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !^/?api(/|$) [NC]
  RewriteCond %{REQUEST_URI} !^/php-backend/ [NC]
  RewriteCond %{REQUEST_URI} !^/assets/
  RewriteCond %{REQUEST_URI} !\.(css|js|jpg|jpeg|png|gif|svg|ico|pdf|woff|woff2|ttf|eot|webp)$ [NC]
  RewriteRule . /appentry.php [L]
</IfModule>

# Set correct MIME types for assets
<IfModule mod_mime.c>
  AddType text/css .css
  AddType application/javascript .js
  AddType application/json .json
  AddType image/jpeg .jpg .jpeg
  AddType image/png .png
  AddType image/gif .gif
  AddType image/svg+xml .svg
  AddType image/webp .webp
  AddType application/pdf .pdf
  AddType font/woff .woff
  AddType font/woff2 .woff2
  AddType font/ttf .ttf
  AddType font/eot .eot
</IfModule>

# Security Headers
<IfModule mod_headers.c>
  # Prevent clickjacking
  Header set X-Frame-Options "SAMEORIGIN"
  # XSS Protection
  Header set X-XSS-Protection "1; mode=block"
  # Prevent MIME type sniffing
  Header set X-Content-Type-Options "nosniff"
  # Never cache the SPA entry point
  <FilesMatch "^(index\.html|index\.php|appentry\.php)$">
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "Thu, 01 Jan 1970 00:00:00 GMT"
    Header always set X-LiteSpeed-Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

# Disable LiteSpeed cache for the SPA entry point (appentry.php + root)
<IfModule LiteSpeed>
  CacheDisable public /
  CacheDisable public /index.html
  CacheDisable public /index.php
  CacheDisable public /appentry.php
</IfModule>

# Cache Control for static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType application/pdf "access plus 1 month"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# Prevent directory listing
Options -Indexes

# Protect sensitive files
<FilesMatch "\.(env|log|ini|conf|sql)$">
  Order allow,deny
  Deny from all
</FilesMatch>
